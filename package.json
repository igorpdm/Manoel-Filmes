{
  "name": "manoel-filmes",
  "version": "1.7.0",
  "description": "Manoel Filmes - Player sincronizado com Bot Discord integrado",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/api/server.ts",
    "dev:bot": "bun --watch src/bot/index.ts",
    "build:css": "tailwindcss -i ./src/styles/main.css -o ./public/styles.css",
    "watch:css": "tailwindcss -i ./src/styles/main.css -o ./public/styles.css --watch",
    "dev:all": "concurrently -n server,bot,css -c blue,magenta,yellow \"bun run dev\" \"bun run dev:bot\" \"bun run watch:css\"",
    "start": "bun src/api/server.ts",
    "start:bot": "bun src/bot/index.ts",
    "start:all": "concurrently -n server,bot -c blue,magenta \"npm:start\" \"npm:start:bot\"",
    "build": "tsc",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "cookie": "^1.1.1",
    "discord.js": "^14.16.3",
    "fluent-ffmpeg": "^2.1.3",
    "sanitize-filename": "^1.6.4",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "^1.3.4",
    "@types/cookie": "^0.6.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.10.7",
    "@types/sanitize-filename": "^1.1.28",
    "@types/yt-search": "^2.10.3",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.3"
  }
}
