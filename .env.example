# Discord Bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
ADMIN_USER_ID=

# Discord OAuth (obter em https://discord.com/developers/applications -> OAuth2)
# DISCORD_CLIENT_SECRET: Client Secret da aplicação Discord
# DISCORD_OAUTH_REDIRECT_URI: URL de callback registrada no Discord (ex: https://seudominio.com/api/oauth/callback)
# SESSION_SECRET: Chave secreta para assinar cookies de sessão (mínimo 32 caracteres, gere com: openssl rand -base64 32)
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/callback
SESSION_SECRET=

# APIs
TMDB_API_KEY=
GEMINI_API_KEY=

# Server
PORT=3000
NODE_ENV=development
DEBUG=false

ALLOWED_ORIGINS=

# Bot -> Player API
PLAYER_URL=http://localhost:3000
PLAYER_API_SHARED_SECRET=